# ChainAlpha — environment variables (live mode)
# All optional. Missing vars fall back to demo/replay adapters.
# Replay mode (?replay=1) never depends on any of these.

# Nexla — world model + position book MCP
NEXLA_SERVICE_KEY=
NEXLA_MCP_URL=

# Pomerium — risk gate in front of MCP tools
POMERIUM_MCP_URL=
POMERIUM_SERVICE_TOKEN=
POMERIUM_MAX_STAKE=2.0

# Zero.xyz — capability discovery, wallet, paper execution
ZERO_API_URL=
ZERO_WALLET_KEY=
ZERO_WALLET_USD=5.00

# Akash — Monte Carlo supply-chain sim worker
AKASH_SIM_URL=
AKASH_LEASE_ID=
AKASH_PROVIDER=

# Optional: live LLM prompt parser (natural-language disruption → structured scenario)
# Leave blank to use the built-in deterministic parser.
# Replay mode never depends on these.
# CHAINALPHA_LLM_URL=
# CHAINALPHA_LLM_KEY=

# ─── Live-transport data layer (observed vessels + aircraft) ───
# Everything below is OPTIONAL. With no keys the app runs in REPLAY using fictionalized
# fixtures. No paid providers are used — only AISStream (free) and ADSB.lol (free, no key).

# AISStream — FREE maritime AIS stream (GitHub sign-in issues the key, no credit card).
# BETA / best-effort, no SLA. REQUIRED for LIVE maritime; without it, maritime is REPLAY.
# The key is used server-side ONLY and never reaches the browser.
AISSTREAM_API_KEY=

# Master switch for all live providers. Set to "false" to force replay everywhere.
# ADSB.lol (aviation) needs NO key and is used live whenever this is "true".
LIVE_TRANSPORT_ENABLED=true

# Default observation region for the live layer: "taiwan" or "red-sea".
LIVE_TRANSPORT_REGION=taiwan

# In-memory snapshot/response cache TTL in seconds (avoids reconnecting per render).
LIVE_TRANSPORT_CACHE_SECONDS=15
