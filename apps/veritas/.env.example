# Engine: headless Claude Code (`claude -p`) — uses your Claude Code
# subscription/login. NO API key needed. Requires the `claude` CLI.
# Optional overrides:
VERITAS_CLAUDE_BIN=
VERITAS_MODEL=opus
VERITAS_MAX_BUDGET_USD=5
VERITAS_TIMEOUT_MS=240000
# Base URL the MCP relay posts back to (defaults to http://localhost:3001)
VERITAS_BASE_URL=

# Paper bankroll
WALLET_USD=100

# Pomerium — live risk gate in front of execute_trade.
# When unset, the policy mirror parses policy/risk.yaml at runtime instead
# (same cap, announced as MIRROR in the UI — never silently).
POMERIUM_MCP_URL=
POMERIUM_SERVICE_TOKEN=

# Nexla — trade journal (log_signal / record_fill via MCP tools/call).
# When unset, entries go to a local journal, shown as MIRROR.
NEXLA_SERVICE_KEY=
NEXLA_MCP_URL=

# Akash — optional Monte Carlo sim worker (stretch)
AKASH_SIM_URL=
